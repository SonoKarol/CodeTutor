# ============================================================
#  Configurazione del Code Tutor Chatbot
#  Copia questo file in ".env" e adatta i valori.
#  (Tutti i valori hanno un default sensato: senza .env il progetto
#   parte già con Ollama + qwen2.5-coder:7b.)
# ============================================================

# Quale motore AI usare:
#   ollama    -> modello open eseguito in locale (DEFAULT, nessuna API esterna)
#   anthropic -> API Claude (richiede ANTHROPIC_API_KEY)
LLM_PROVIDER=ollama

# Porta su cui gira il server web.
PORT=3000


# ----------------------------------------------------------------
#  Opzioni per LLM_PROVIDER=ollama  (modello locale)
# ----------------------------------------------------------------

# Nome del modello Ollama da usare. Per cambiarlo:
#   1) scaricalo:        ollama pull <nome-modello>
#   2) metti qui il nome (es. OLLAMA_MODEL=llama3.1:8b)
#   3) riavvia il server
# Vedi i modelli installati con:  ollama list
OLLAMA_MODEL=qwen2.5-coder:7b

# Endpoint dell'API (compatibile OpenAI) esposta da Ollama.
# Di norma non va cambiato; modificalo solo se Ollama gira su un'altra macchina/porta.
OLLAMA_BASE_URL=http://localhost:11434/v1

# Nasconde il ragionamento dei "thinking model" (es. Qwen3.5):
#   true  (default) -> mostra solo la risposta finale
#   false           -> mostra anche il ragionamento, prima della risposta
HIDE_THINKING=true


# ----------------------------------------------------------------
#  Opzioni per LLM_PROVIDER=anthropic  (Claude)
# ----------------------------------------------------------------

# Chiave API Anthropic (https://console.anthropic.com/). Obbligatoria solo se usi anthropic.
ANTHROPIC_API_KEY=sk-ant-...

# Modello Claude: claude-opus-4-8 | claude-sonnet-4-6 | claude-haiku-4-5
MODEL=claude-opus-4-8

# Profondità di ragionamento: low | medium | high | max
EFFORT=medium

# Numero massimo di token in output per ogni risposta (solo Claude).
MAX_TOKENS=8000


# ----------------------------------------------------------------
#  Robustezza (vale per entrambi i provider)
# ----------------------------------------------------------------

# Limite di richieste per IP nella finestra di tempo (anti-abuso).
RATE_LIMIT_MAX=30
# Durata della finestra del rate limit, in secondi.
RATE_LIMIT_WINDOW_SECONDS=60

# Lunghezza massima (in caratteri) di ogni singolo messaggio, cronologia inclusa.
# Default 100000. Metti 0 per togliere del tutto il limite.
MAX_CHARS_PER_MESSAGE=100000


# ----------------------------------------------------------------
#  Dashboard di monitoraggio accessi (chi usa il sito e da dove)
# ----------------------------------------------------------------

# Token segreto per accedere alla dashboard su /admin?token=...
# Se vuoto, la dashboard è disabilitata (il log nel terminale funziona comunque).
# Generane uno casuale, es. con:  node -e "console.log(require('crypto').randomBytes(12).toString('hex'))"
ADMIN_TOKEN=
